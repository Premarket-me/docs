{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Premarket Docs",
  "theme": "mint",
  "colors": {
    "primary": "#0EA5E9",
    "light": "#0EA5E9",
    "dark": "#38BDF8"
  },
  "logo": {
    "light": "/images/premarket-logo.png",
    "dark": "/images/premarket-logo.png"
  },
  "favicon": "/favicon.ico",
  "navigation": {
