          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Backend API",
            "openapi": {
              "source": "https://api.premarket.me/openapi.json",
              "directory": "api-reference"
            }
          }
        ]
      }
    ]
  }
